{
  "extends": "solhint:recommended",
  "plugins": ["prettier"],
  "rules": {
    "compiler-version": ["error", "^0.8.0"],
    "func-visibility": ["warn", { "ignoreConstructors": true }],
    "prettier/prettier": "error",
    "not-rely-on-time": "off",
    "no-empty-blocks": "off",
    "avoid-low-level-calls": "off",
    "no-global-import": "off"
  }
}
